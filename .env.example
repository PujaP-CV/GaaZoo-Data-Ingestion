# ── GaaZoo Unified Platform — Environment Variables ──────────────────────────
# Copy this file to .env and fill in your values.
# Never commit the actual .env file.

# ── Flask ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-string
DEBUG=True

# ── Meshy AI (image → 3D conversion) ─────────────────────────────────────────
# Get your key at https://www.meshy.ai/
MESHY_API_KEY=

# ── Amazon Product Search (RapidAPI) ─────────────────────────────────────────
# Subscribe at https://rapidapi.com/letscrape-6bRBa3QguO5/api/real-time-amazon-data
RAPIDAPI_KEY=
RAPIDAPI_AMAZON_HOST=real-time-amazon-data.p.rapidapi.com

# ── Google Image Search (SerpAPI) ─────────────────────────────────────────────
# Get your key at https://serpapi.com/
SERPAPI_KEY=

# ── Neo4j Graph Database ──────────────────────────────────────────────────────
# Start Neo4j locally or use Aura (https://neo4j.com/cloud/aura/)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# ── Pinterest OAuth ───────────────────────────────────────────────────────────
# Register app at https://developers.pinterest.com/apps/
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=
PINTEREST_REDIRECT_URI=http://localhost:5000/auth/pinterest/callback

# ── Spotify OAuth ─────────────────────────────────────────────────────────────
# Register app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:5000/auth/spotify/callback

# ── Google Gemini AI ──────────────────────────────────────────────────────────
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── ProcessIQ Vanilla Prompt API ─────────────────────────────────────────────
VANILLA_LLM=openai
IMAGE_QUESTION_TEMPLATE_ID=19

# ── Catalog defaults ──────────────────────────────────────────────────────────
DEFAULT_CATALOG_NAME=GaaZoo Catalog
DEFAULT_VENDOR_NAME=Amazon
DEFAULT_VENDOR_DOMAIN=amazon.com
